{
  "name": "pposkasir",
  "version": "1.0.1",
  "description": "PPOS Kasir Desktop App",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win nsis appx",
    "build:win:exe": "npm run build && electron-builder --win nsis",
    "build:win:store": "npm run build && electron-builder --win appx",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@mui/styled-engine-sc": "^7.3.8",
    "better-sqlite3": "^12.8.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.3.9",
    "i18next": "^26.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.13.1",
    "styled-components": "^6.3.11",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.6"
  },
  "build": {
    "productName": "P-POS Kasir",
    "appId": "com.ppos.kasir",
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "MhmmdSyahputra",
        "repo": "pposkasir_desktopapp",
        "private": true
      }
    ],
    "directories": {
      "buildResources": "resources"
    },
    "extraResources": [
      "./resources/**"
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "win": {
      "icon": "resources/ico.ico",
      "target": [
        "nsis",
        "appx"
      ]
    },
    "appx": {
      "applicationId": "pposkasir",
      "displayName": "P-POS Kasir",
      "publisherDisplayName": "putrapt",
      "identityName": "putrapt.P-POSKasir",
      "publisher": "CN=84050BA2-CA6C-41F7-AC8B-EDCA1D84EEED"
    }
  }
}
